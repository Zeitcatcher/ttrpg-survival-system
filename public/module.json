{
  "id": "ttrpg-survival-system",
  "title": "TTRPG Survival System",
  "description": "System-agnostic survival tracking for Foundry VTT: water, food, and firewood across party, storage, and mounts, with graded hunger/thirst/cold and climate. Pathfinder 2e first.",
  "version": "1.1.1",
  "url": "https://github.com/Zeitcatcher/ttrpg-survival-system",
  "manifest": "https://github.com/Zeitcatcher/ttrpg-survival-system/releases/latest/download/module.json",
  "download": "https://github.com/Zeitcatcher/ttrpg-survival-system/releases/download/v1.1.1/module.zip",
  "compatibility": {
    "minimum": "13",
    "verified": "14"
  },
  "esmodules": ["scripts/module.js"],
  "styles": ["styles/survival.css"],
  "languages": [
    { "lang": "en", "name": "English", "path": "lang/en.json" },
    { "lang": "ru", "name": "Русский", "path": "lang/ru.json" }
  ],
  "relationships": {
    "requires": [
      { "id": "socketlib", "type": "module" }
    ],
    "systems": [
      { "id": "pf2e", "type": "system" }
    ]
  },
  "authors": [{ "name": "Zeitcatcher" }],
