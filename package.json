{
  "name": "ttrpg-survival-system",
  "private": true,
  "version": "0.1.5",
  "type": "module",
  "description": "System-agnostic survival module for Foundry VTT (water/food/firewood, hunger/thirst/cold). PF2e first.",
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint ."
  },
  "devDependencies": {
    "eslint": "^9.13.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.10.0",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
