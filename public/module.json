  "readme": "https://github.com/Zeitcatcher/ttrpg-survival-system#readme",
  "changelog": "https://github.com/Zeitcatcher/ttrpg-survival-system/blob/main/CHANGELOG.md",
  "bugs": "https://github.com/Zeitcatcher/ttrpg-survival-system/issues"
}
